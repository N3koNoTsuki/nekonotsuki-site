# --- Database (SQLite via Prisma) ---
# To migrate to PostgreSQL later: change provider in prisma/schema.prisma and this URL.
DATABASE_URL="file:./dev.db"

# --- NextAuth v5 ---
# Generate a strong secret:  openssl rand -base64 32
AUTH_SECRET="change-me-please-generate-a-real-secret"
# Required when running behind a proxy / on a VPS (not strictly needed on Vercel)
AUTH_TRUST_HOST=true

# --- Owner account (seeded into the DB by `npm run db:seed`) ---
OWNER_EMAIL="owner@nekonotsuki.dev"
OWNER_PASSWORD="changeme123"
OWNER_NAME="Neko"
