// Prisma schema — NekoNoTsuki portfolio
// PostgreSQL (Neon recommended) — works on Vercel and any serverless host.
// DATABASE_URL = your Neon "Direct connection" string (with ?sslmode=require).
// Init once:  npx prisma db push  &&  npm run db:seed

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Single owner account (credentials auth via NextAuth)
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String // bcrypt hash
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Configurable blocks shown on the home page (reorderable via drag & drop)
model HomeBlock {
  id        String   @id @default(cuid())
  // intro | latest-projects | latest-favorites | latest-timeline | custom
  type      String
  title     String?
  content   String? // markdown (intro / custom blocks)
  config    String? // JSON string for per-block options (e.g. {"count":3})
  order     Int      @default(0)
  visible   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Favorites categories (Musique/Vocaloid, Anime, Jeux, Logiciels, custom...)
model Category {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  icon      String? // optional emoji/icon
  order     Int        @default(0)
  items     Favorite[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Favorite {
  id          String   @id @default(cuid())
  title       String
  imageUrl    String? // local /uploads path or external URL
  description String? // markdown
  rating      Int? // personal note 1-5
  comment     String? // short personal comment (plain text)
  order       Int      @default(0)
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([categoryId])
}

model TimelineEntry {
  id          String   @id @default(cuid())
  date        DateTime
  title       String
  description String? // markdown
  tag         String   @default("perso") // etudes | pro | perso | projet
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Project {
  id          String   @id @default(cuid())
  title       String
  coverUrl    String? // local /uploads path or external URL
  description String? // markdown (short)
  tags        String   @default("") // comma-separated tags
  githubUrl   String?
  demoUrl     String?
  order       Int      @default(0)
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Free-form markdown pages (currently: "about"); extensible to others.
model Page {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String?
  content   String   @default("") // markdown
  updatedAt DateTime @updatedAt
}
